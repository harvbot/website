# Copy this file to .env.local and fill in your values.
# Next.js loads .env.local automatically — no dotenv setup required.
# Never commit .env.local to version control.

# Public site URL — used for canonical URLs, OG tags, sitemap, and JSON-LD
# Set this to your custom domain in Vercel environment variables
NEXT_PUBLIC_SITE_URL=https://countyfarmcollective.ca

# LocalLine backoffice credentials
# Used by the subscribe action and vendor data fetching
LOCALLINE_USERNAME=
LOCALLINE_PASSWORD=
